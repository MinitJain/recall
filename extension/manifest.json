{
  "manifest_version": 3,
  "name": "Recall",
  "version": "1.0.0",
  "description": "Bookmark manager to save anything from the web in one click. AI tags it automatically. Search and resurface your saves anytime.",

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Recall",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "background": {
    "service_worker": "serviceworker.js"
  },

  "commands": {
    "save-bookmark": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Save current page to Recall"
    }
  },

  "permissions": ["activeTab", "storage"],

  "host_permissions": ["http://localhost:3000/*", "http://localhost:3001/*", "https://gfdwrzaeofehgpwuulvr.supabase.co/*", "https://recallsave.vercel.app/*"]
}
