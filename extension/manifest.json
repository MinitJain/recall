{
  "manifest_version": 3,
  "name": "Recall",
  "version": "1.0.0",
  "description": "Save anything. Find everything.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Recall"
  },

  "background": {
    "service_worker": "serviceworker.js"
  },

  "permissions": ["activeTab", "storage"],

  "host_permissions": ["http://localhost:3000/*", "http://localhost:3001/*", "https://gfdwrzaeofehgpwuulvr.supabase.co/*"]
}
