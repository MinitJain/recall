# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres — get these from Supabase project settings > Database > Connection string
# DATABASE_URL uses the pooled connection (port 6543) — used at runtime
# DIRECT_URL uses the direct connection (port 5432) — used by Prisma CLI only
DATABASE_URL=
DIRECT_URL=

# Upstash Redis — get these from upstash.com > your database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Gemini — get this from aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Comma-separated list of emails that can access /admin
ADMIN_EMAILS=

# Base URL of this app — used for bookmarklet links
# Local: http://localhost:3000
# Production: https://recallsave.vercel.app
NEXT_PUBLIC_APP_URL=

# Daily digest — Vercel injects this automatically when firing cron jobs
# Generate locally with: openssl rand -hex 32
CRON_SECRET=

# Resend email API — get from resend.com (free, no card needed)
RESEND_API_KEY=
